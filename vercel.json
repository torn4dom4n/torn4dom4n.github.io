{
  "name": "@torn4dom4n/website",
  "framework": "vite",
  "buildCommand": "vp build",
  "outputDirectory": "dist/client",
  "github": {
    "autoJobCancelation": true
  },
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
